# 로컬링크 환경 변수 — 이 파일을 복사해 .env 를 만들고 아래 값을 채우세요.
#   ./setup-env.sh
# 백엔드(main.py)와 docker compose 가 저장소 루트의 .env 를 읽습니다.
# .env 는 git 에 올라가지 않습니다.

# ═══════════════════════════════════════════════════════════
# API 키 (여기에 붙여넣기)
# ═══════════════════════════════════════════════════════════

# Claude — 음성 도우미(구매·판매), 판매 글 «설명 자동 작성»
# https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=
# 두 번째 키 (할당량·장애 시 자동 순환)
ANTHROPIC_API_KEY_2=
# 또는 한 줄에: ANTHROPIC_API_KEYS=sk-ant-...,sk-ant-...

# OpenAI — 판매 글 «대표 사진 AI 생성», A2A 검수
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# 두 번째 키 (할당량·장애 시 자동 순환)
OPENAI_API_KEY_2=
# 또는 한 줄에: OPENAI_API_KEYS=sk-...,sk-...

# Google Gemini — A2A 3·4차 검수 (선택)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GOOGLE_API_KEY=   # GEMINI_API_KEY 와 동일 (둘 중 하나)
# GEMINI_MODEL=gemini-2.0-flash

# 이미지 생성 — OpenAI DALL·E (권장) 또는 Pollinations
# LOCAL_LINK_IMAGE_PROVIDER=openai  ← OPENAI_API_KEY 있으면 기본 openai
# OPENAI_IMAGE_MODEL=gpt-image-1.5  ← 비우면 gpt-image → dall-e 순 자동 시도
# OPENAI_IMAGE_QUALITY=standard     ← dall-e-3 전용: standard | hd
OPENAI_IMAGE_MODEL=gpt-image-1.5
LOCAL_LINK_IMAGE_PROVIDER=openai

# 프록시·Azure 등 쓸 때만 설정 (공식 API면 이 줄 자체를 넣지 마세요 — 빈 값이면 오류)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ═══════════════════════════════════════════════════════════
# 음성 인식 (ASR) — 로컬 터미널에서 uvicorn 쓸 때
# ═══════════════════════════════════════════════════════════

# dummy = 모델 안 불러옴 (UI·API 빠른 확인)
# 비우기 = Whisper (TTT_MODEL_ID 또는 TTT_MODEL_PATH)
TTT_ASR_BACKEND=

# 프리셋: elderly_command | gangwon | combined
TTT_MODEL_ID=elderly_command

# 직접 경로 (있으면 TTT_MODEL_ID 보다 우선). 저장소 루트 기준 상대 경로 가능
# TTT_MODEL_PATH=models/inference/elderly_command
TTT_MODEL_PATH=

# Docker: 마운트할 체크포인트 폴더 (TTT_MODEL_ID 와 맞추기)
TTT_MODEL_DIR=./models/inference/elderly_command

# ASR 오타 교정 — max: 규칙 + Claude 2에이전트 + OpenAI 검수 (키 있을 때)
# a2a: Claude만 | rules: 규칙만 | off: Whisper 원문 그대로
TTT_ASR_CORRECTION=max

# 슬롯 검수·등록 감사·설명/이미지/SNS A2A — max | a2a | rules | off
TTT_AGENT_PIPELINE=max

# 시연 모드(1) — A2A max(Claude+OpenAI+Gemini) 유지, 안정성 폴백만 강화
TTT_DEMO_MODE=1

# ═══════════════════════════════════════════════════════════
# 노트 OCR — CLOVA (네이버) + Claude 구조화
# ═══════════════════════════════════════════════════════════

# clova = CLOVA OCR로 글자 추출 → Claude가 폼 항목 정리 (키 있으면 기본)
# claude = Claude Vision만 (이미지 직접)
LOCAL_LINK_OCR_PROVIDER=clova

# CLOVA OCR Builder → 도메인 → API Gateway 연동(자동) 후 발급
# ❌ clovaocr-api-kr.ncloud.com (내부 주소) — 연결 거부됨
# ✅ https://xxxx.apigw.ntruss.com/custom/v1/패키지ID/앱ID/general
CLOVA_OCR_API_URL=
CLOVA_OCR_SECRET=

# ═══════════════════════════════════════════════════════════
# 선택
# ═══════════════════════════════════════════════════════════

# CORS_EXTRA_ORIGINS=http://192.168.0.10:5173
# DATABASE_URL=sqlite:///./webapp/backend/data/runtime/local_link.db

# 데모 시드 14건 다시 넣기 (기존 DB 목록 삭제 후 listings.seed.json 로드)
# LOCAL_LINK_RESEED=1

# ═══════════════════════════════════════════════════════════
# 회원 · 마스터 (운영자) 로그인
# ═══════════════════════════════════════════════════════════

# JWT 서명용 (운영 환경에서는 반드시 긴 랜덤 문자열로 변경)
# LOCAL_LINK_AUTH_SECRET=

# 마스터 계정 — DB에 없음, .env 로만 로그인
LOCAL_LINK_MASTER_EMAIL=master@local-link.kr
LOCAL_LINK_MASTER_PASSWORD=change-me-master
